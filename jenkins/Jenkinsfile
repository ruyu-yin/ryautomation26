pipeline {
    agent any

    environment {
        REPORTS_DIR = 'reports'
        DATABASE_DIR = 'database'
    }

    stages {
        stage('📥 Checkout') {
            steps {
                echo 'Checking out code...'
                checkout scm
                dir('reports') {
                    deleteDir()
                }
            }
        }

        stage('📦 安装依赖') {
            steps {
                echo 'Installing Python dependencies...'
                sh 'pip3 install -r requirements.txt'
            }
        }

        stage('🧪 运行测试') {
            steps {
                echo 'Running tests...'
                sh '''
                    mkdir -p reports/html reports/markdown reports/allure-results
                    python3 src/run_tests.py
                '''
            }
            post {
                always {
                    echo 'Test stage completed'
                }
            }
        }

        stage('📊 生成报告') {
            steps {
                echo 'Generating reports...'
                sh 'python3 src/utils/report_generator.py'
            }
        }

        stage('📤 归档报告') {
            steps {
                echo 'Archiving reports...'
                script {
                    archiveArtifacts artifacts: 'reports/**/*', allowEmptyArchive: true
                    archiveArtifacts artifacts: 'database/**/*', allowEmptyArchive: true
                }
            }
        }

        stage('📢 发送通知') {
            steps {
                echo 'Sending notifications...'
                sh 'python3 src/utils/notification.py'
            }
            post {
                always {
                    echo 'Notification stage completed'
                }
            }
        }
    }

    post {
        always {
            echo 'Pipeline finished!'
            // 清理工作空间（可选）
            // cleanWs()
        }
        success {
            echo '✅ All tests passed!'
        }
        failure {
            echo '❌ Some tests failed! Check reports.'
        }
    }
}